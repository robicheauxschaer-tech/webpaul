# Environment Variables Example
# Copy this file to .env and set your actual values

# ICO Contract Address (BSC) - Replace with your actual deployed contract address
VITE_ICO_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# WalletConnect Project ID - Get from https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# USDT Contract Address on BSC (mainnet) - Already set to the correct address
VITE_USDT_CONTRACT_ADDRESS=0x55d398326f99059fF775485246999027B3197955
